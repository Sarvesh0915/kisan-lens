<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KisanLens – Confirm Deletion</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;800&family=Noto+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Noto Sans', sans-serif; }
    .brand { font-family: 'Baloo 2', cursive; }
    .leaf-bg {
      background-color: #0f4c2a;
      background-image:
        radial-gradient(ellipse at 20% 80%, rgba(34,197,94,0.18) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 20%, rgba(250,204,21,0.12) 0%, transparent 50%);
    }
    .card-shadow { box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
    .otp-box {
      width: 48px; height: 56px;
      font-size: 1.4rem; font-weight: 700;
      text-align: center;
      border: 2px solid #fecaca;
      border-radius: 12px;
      background: #fef2f2;
      color: #991b1b;
      caret-color: #dc2626;
    }
    .otp-box:focus { border-color: #dc2626; outline: none; box-shadow: 0 0 0 3px rgba(220,38,38,0.25); }
  </style>
</head>
<body class="leaf-bg min-h-screen flex items-center justify-center px-4 py-10">

  <div class="w-full max-w-sm">

    <div class="text-center mb-7">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-100 mb-3 shadow-lg">
        <span class="text-3xl">⚠️</span>
      </div>
      <h1 class="brand text-3xl text-white font-extrabold">KisanLens</h1>
      <p class="text-green-300 text-sm">Confirm account deletion</p>
    </div>

    <div class="bg-white rounded-3xl card-shadow px-7 py-8">

      <h2 class="brand text-2xl text-gray-800 font-bold mb-1">Enter OTP</h2>
      <p class="text-gray-500 text-sm mb-5">
        We sent a 6-digit code to <strong>{{ masked_phone }}</strong> to confirm you want to
        permanently delete this account.
      </p>

      {% with messages = get_flashed_messages(with_categories=true) %}
        {% for category, message in messages %}
          <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium
            {% if category == 'error' %}bg-red-50 text-red-700 border border-red-200
            {% else %}bg-green-50 text-green-700 border border-green-200{% endif %}">
            {{ message }}
          </div>
        {% endfor %}
      {% endwith %}

      <form method="POST" action="/delete-account/confirm" class="space-y-5" onsubmit="return confirm('This is your final confirmation. Your account and all data will be permanently deleted. Continue?');">
        <div class="flex justify-between gap-2">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp1" required autofocus />
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp2" required />
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp3" required />
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp4" required />
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp5" required />
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" name="otp6" required />
        </div>

        <button
          type="submit"
          class="w-full bg-red-600 hover:bg-red-700 active:scale-95 text-white font-bold text-lg rounded-xl py-3.5 transition-all duration-150 shadow-md"
        >
          Permanently Delete My Account
        </button>
      </form>

      <p class="text-center text-gray-500 text-sm mt-5">
        Changed your mind?
        <a href="/login" class="text-green-600 font-semibold hover:underline">Go back</a>
      </p>
    </div>

    <p class="text-center text-green-300/60 text-xs mt-5">
      KisanLens · Built for Bharat's Farmers
    </p>
  </div>

  <script>
    // Auto-advance between OTP boxes
    const boxes = Array.from(document.querySelectorAll('.otp-box'));
    boxes.forEach((box, i) => {
      box.addEventListener('input', () => {
        box.value = box.value.replace(/\D/g, '').slice(-1);
        if (box.value && i < boxes.length - 1) boxes[i + 1].focus();
      });
      box.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !box.value && i > 0) boxes[i - 1].focus();
      });
    });
  </script>

</body>
</html>
